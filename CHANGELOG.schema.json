{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ANcpLua/renovate-config/blob/main/CHANGELOG.schema.json",
  "title": "Automation changelog entry",
  "type": "array",
  "maxItems": 10,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["timestamp", "title", "summary", "evidence", "actions", "blocked"],
    "properties": {
      "timestamp": {
        "type": "string",
        "format": "date-time"
      },
      "title": {
        "type": "string",
        "minLength": 1
      },
      "summary": {
        "type": "string",
        "minLength": 1
      },
      "evidence": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "actions": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "blocked": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
