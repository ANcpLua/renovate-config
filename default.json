{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "ANcpLua framework — shared Renovate baseline (used by ANcpLua.NET.Sdk, ANcpLua.Roslyn.Utilities, ANcpLua.Analyzers, ANcpLua.Agents)",
  "extends": [
    "config:best-practices",
    ":semanticCommits",
    ":enableVulnerabilityAlerts"
  ],
  "timezone": "UTC",
  "dependencyDashboard": true,
  "commitMessagePrefix": "deps:",
  "labels": ["dependencies"],
  "platformAutomerge": true,
  "prHourlyLimit": 2,
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "description": "Hygiene: digest pins + lockfile maintenance — content-locking, automerge always",
      "matchUpdateTypes": ["pin", "digest", "pinDigest", "lockFileMaintenance"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Patch bumps — automerge if CI is green (cross-ecosystem)",
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "npm devDependencies — minor bumps automerge (build-time only, no runtime risk)",
      "matchManagers": ["npm"],
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Block unstable npm versions by default — alpha/beta/rc/preview/pre/dev/canary/next/nightly",
      "matchManagers": ["npm"],
      "allowedVersions": "!/(?:alpha|beta|rc|preview|pre|dev|canary|next|nightly)/i"
    },
    {
      "description": "Block unstable NuGet versions by default — alpha/beta/preview/pre/dev/experimental/nightly. RC is allowed; the MAF matrix and per-package exceptions below override as needed",
      "matchDatasources": ["nuget"],
      "allowedVersions": "!/(?:alpha|beta|preview|pre|dev|experimental|nightly)/i"
    },
    {
      "description": "Known-prerelease NuGet exceptions: first-party packages plus upstreams with no stable release. Resets allowedVersions so the default-deny does not freeze legitimate prerelease pins",
      "matchDatasources": ["nuget"],
      "matchPackageNames": [
        "/^ANcpLua\\./",
        "Microsoft.OpenApi.Readers",
        "JonSkeet.RoslynAnalyzers"
      ],
      "ignoreUnstable": false,
      "respectLatest": false,
      "allowedVersions": "*"
    },
    {
      "description": "ANcpLua first-party (cross-repo) — automerge minor/patch",
      "matchPackageNames": ["/^ANcpLua\\./"],
      "groupName": "ancplua-sdk",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Roslyn analyzers + reference assemblies",
      "matchPackageNames": [
        "/^Microsoft\\.CodeAnalysis/",
        "/^Basic\\.Reference\\.Assemblies/"
      ],
      "groupName": "roslyn",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Microsoft.Extensions / BCL / Channels / ASP.NET",
      "matchPackageNames": [
        "/^Microsoft\\.Extensions/",
        "/^Microsoft\\.Bcl/",
        "/^System\\.Threading\\.Channels/",
        "/^Microsoft\\.AspNetCore/"
      ],
      "groupName": "microsoft-extensions",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "AI client packages excluding Microsoft Agent Framework package-status matrix",
      "matchDatasources": ["nuget"],
      "matchPackageNames": [
        "/^Microsoft\\.Extensions\\.AI/",
        "/^OpenAI/",
        "/^Azure\\.AI\\.OpenAI/",
        "/^Anthropic\\.SDK/",
        "/^OllamaSharp/",
        "/^Mscc\\.GenerativeAI/"
      ],
      "groupName": "ai-client-packages",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Meziantou family",
      "matchPackageNames": ["/^Meziantou\\./"],
      "groupName": "meziantou",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Test frameworks (xUnit / NUnit / TUnit / bunit / MTP / AwesomeAssertions / Moq)",
      "matchPackageNames": [
        "/^xunit/",
        "/^NUnit/",
        "/^TUnit/",
        "/^bunit/",
        "/^Microsoft\\.Testing/",
        "/^Microsoft\\.NET\\.Test/",
        "/^AwesomeAssertions/",
        "/^Moq/",
        "/^GitHubActionsTestLogger/",
        "/^coverlet/"
      ],
      "groupName": "testing",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "OpenAPI / YAML",
      "matchPackageNames": ["/^Microsoft\\.OpenApi/", "/^YamlDotNet/"],
      "groupName": "openapi",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "OpenTelemetry",
      "matchPackageNames": ["/^OpenTelemetry/"],
      "groupName": "opentelemetry",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Major bumps require manual review by default",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major"]
    },
    {
      "description": "MAF stable packages — stable versions only, automerge including majors",
      "matchDatasources": ["nuget"],
      "matchPackageNames": [
        "Microsoft.Agents.AI",
        "Microsoft.Agents.AI.Abstractions",
        "Microsoft.Agents.AI.Foundry",
        "Microsoft.Agents.AI.OpenAI",
        "Microsoft.Agents.AI.Workflows",
        "Microsoft.Agents.AI.Workflows.Generators"
      ],
      "groupName": "microsoft-agent-framework-stable",
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+$/",
      "automerge": true,
      "automergeType": "pr",
      "dependencyDashboardApproval": false,
      "labels": ["dependencies", "microsoft-agent-framework", "stable"],
      "prPriority": 5,
      "prBodyNotes": [
        "ANcpLua Microsoft Agent Framework matrix 2026-05-05: this package is stable-track. Stable versions only; preview/alpha/beta/dev builds are intentionally excluded."
      ]
    },
    {
      "description": "MAF RC packages — stable or RC versions only, automerge including majors",
      "matchDatasources": ["nuget"],
      "matchPackageNames": [
        "Microsoft.Agents.AI.Declarative",
        "Microsoft.Agents.AI.Purview",
        "Microsoft.Agents.AI.Workflows.Declarative",
        "Microsoft.Agents.AI.Workflows.Declarative.Foundry"
      ],
      "groupName": "microsoft-agent-framework-rc",
      "ignoreUnstable": false,
      "respectLatest": false,
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+(?:-[Rr][Cc]\\d+)?$/",
      "automerge": true,
      "automergeType": "pr",
      "dependencyDashboardApproval": false,
      "labels": ["dependencies", "microsoft-agent-framework", "rc"],
      "prPriority": 4,
      "prBodyNotes": [
        "ANcpLua Microsoft Agent Framework matrix 2026-05-05: this package is RC-track. Stable and RC versions are allowed; preview/alpha/beta/dev builds are intentionally excluded."
      ]
    },
    {
      "description": "MAF preview/alpha packages — do not suggest preview/alpha; allow only future stable or RC with manual approval",
      "matchDatasources": ["nuget"],
      "matchPackageNames": [
        "Aspire.Hosting.AgentFramework.DevUI",
        "Microsoft.Agents.AI.A2A",
        "Microsoft.Agents.AI.AGUI",
        "Microsoft.Agents.AI.Anthropic",
        "Microsoft.Agents.AI.AzureAI.Persistent",
        "Microsoft.Agents.AI.CopilotStudio",
        "Microsoft.Agents.AI.CosmosNoSql",
        "Microsoft.Agents.AI.DevUI",
        "Microsoft.Agents.AI.DurableTask",
        "Microsoft.Agents.AI.Foundry.Hosting",
        "Microsoft.Agents.AI.FoundryMemory",
        "Microsoft.Agents.AI.GitHub.Copilot",
        "Microsoft.Agents.AI.Hosting",
        "Microsoft.Agents.AI.Hosting.A2A",
        "Microsoft.Agents.AI.Hosting.A2A.AspNetCore",
        "Microsoft.Agents.AI.Hosting.AGUI.AspNetCore",
        "Microsoft.Agents.AI.Hosting.AzureFunctions",
        "Microsoft.Agents.AI.Hosting.OpenAI",
        "Microsoft.Agents.AI.ProjectTemplates"
      ],
      "groupName": "microsoft-agent-framework-preview-alpha-quarantine",
      "ignoreUnstable": false,
      "respectLatest": false,
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+(?:-[Rr][Cc]\\d+)?$/",
      "automerge": false,
      "dependencyDashboardApproval": true,
      "labels": ["dependencies", "microsoft-agent-framework", "preview-or-alpha", "manual-review"],
      "prPriority": -5,
      "prBodyNotes": [
        "ANcpLua Microsoft Agent Framework matrix 2026-05-05: this package is preview/alpha-track. Renovate may propose only future stable or RC releases; preview/alpha/beta/dev builds are intentionally excluded and never automerged."
      ]
    },
    {
      "description": "MAF legacy package — migrate AzureAI naming to Foundry",
      "matchDatasources": ["nuget"],
      "matchPackageNames": ["Microsoft.Agents.AI.AzureAI"],
      "replacementName": "Microsoft.Agents.AI.Foundry",
      "replacementVersion": "1.4.0",
      "automerge": false,
      "dependencyDashboardApproval": true,
      "labels": ["dependencies", "microsoft-agent-framework", "legacy", "migration"],
      "prBodyNotes": [
        "Microsoft.Agents.AI.AzureAI is marked superseded in the ANcpLua Microsoft Agent Framework matrix 2026-05-05. Prefer Microsoft.Agents.AI.Foundry. Replacement rules do not apply to custom.regex-managed Version.props entries, so Version.props migrations may require manual edits."
      ]
    },
    {
      "description": "MAF legacy package — migrate Declarative AzureAI workflows to Declarative Foundry workflows",
      "matchDatasources": ["nuget"],
      "matchPackageNames": ["Microsoft.Agents.AI.Workflows.Declarative.AzureAI"],
      "replacementName": "Microsoft.Agents.AI.Workflows.Declarative.Foundry",
      "replacementVersion": "1.4.0-rc1",
      "automerge": false,
      "dependencyDashboardApproval": true,
      "labels": ["dependencies", "microsoft-agent-framework", "legacy", "migration"],
      "prBodyNotes": [
        "Microsoft.Agents.AI.Workflows.Declarative.AzureAI is marked superseded in the ANcpLua Microsoft Agent Framework matrix 2026-05-05. Prefer Microsoft.Agents.AI.Workflows.Declarative.Foundry. Replacement rules do not apply to custom.regex-managed Version.props entries, so Version.props migrations may require manual edits."
      ]
    },
    {
      "description": "MAF legacy preview package — migrate FoundryMemory to Foundry",
      "matchDatasources": ["nuget"],
      "matchPackageNames": ["Microsoft.Agents.AI.FoundryMemory"],
      "replacementName": "Microsoft.Agents.AI.Foundry",
      "replacementVersion": "1.4.0",
      "automerge": false,
      "dependencyDashboardApproval": true,
      "labels": ["dependencies", "microsoft-agent-framework", "legacy", "preview", "migration"],
      "prBodyNotes": [
        "Microsoft.Agents.AI.FoundryMemory is marked superseded in the ANcpLua Microsoft Agent Framework matrix 2026-05-05. Prefer Microsoft.Agents.AI.Foundry. Replacement rules do not apply to custom.regex-managed Version.props entries, so Version.props migrations may require manual edits."
      ]
    },
    {
      "description": ".NET SDK — stable channel only, block previews",
      "matchManagers": ["dotnet-sdk"],
      "matchPackageNames": ["dotnet-sdk"],
      "allowedVersions": "/^[0-9]+\\.[0-9]+\\.[0-9]+$/"
    }
  ],
