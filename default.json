{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "ANcpLua framework — shared Renovate baseline (used by ANcpLua.NET.Sdk, ANcpLua.Roslyn.Utilities, ANcpLua.Analyzers, ANcpLua.Agents)",
  "extends": [
    "config:best-practices",
    ":semanticCommits",
    ":enableVulnerabilityAlerts"
  ],
  "timezone": "UTC",
  "dependencyDashboard": true,
  "commitMessagePrefix": "deps:",
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "ANcpLua first-party (cross-repo) — automerge minor/patch",
      "matchPackageNames": ["/^ANcpLua\\./"],
      "groupName": "ancplua-sdk",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Roslyn analyzers + reference assemblies",
      "matchPackageNames": [
        "/^Microsoft\\.CodeAnalysis/",
        "/^Basic\\.Reference\\.Assemblies/"
      ],
      "groupName": "roslyn",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Microsoft.Extensions / BCL / Channels / ASP.NET",
      "matchPackageNames": [
        "/^Microsoft\\.Extensions/",
        "/^Microsoft\\.Bcl/",
        "/^System\\.Threading\\.Channels/",
        "/^Microsoft\\.AspNetCore/"
      ],
      "groupName": "microsoft-extensions",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "MAF — Microsoft.Agents.AI + Microsoft.Extensions.AI + OpenAI clients",
      "matchPackageNames": [
        "/^Microsoft\\.Agents\\.AI/",
        "/^Microsoft\\.Extensions\\.AI/",
        "/^OpenAI/",
        "/^Azure\\.AI\\.OpenAI/",
        "/^Anthropic\\.SDK/",
        "/^OllamaSharp/",
        "/^Mscc\\.GenerativeAI/"
      ],
      "groupName": "microsoft-agents-ai",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "MAF Pre-Release tracks (preview/rc) — manual review",
      "matchPackageNames": ["/^Microsoft\\.Agents\\.AI/"],
      "matchCurrentVersion": "/-(preview|rc|alpha|beta)/",
      "automerge": false
    },
    {
      "description": "Meziantou family",
      "matchPackageNames": ["/^Meziantou\\./"],
      "groupName": "meziantou",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Test frameworks (xUnit / NUnit / TUnit / bunit / MTP / AwesomeAssertions / Moq)",
      "matchPackageNames": [
        "/^xunit/",
        "/^NUnit/",
        "/^TUnit/",
        "/^bunit/",
        "/^Microsoft\\.Testing/",
        "/^Microsoft\\.NET\\.Test/",
        "/^AwesomeAssertions/",
        "/^Moq/",
        "/^GitHubActionsTestLogger/",
        "/^coverlet/"
      ],
      "groupName": "testing",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "OpenAPI / YAML",
      "matchPackageNames": ["/^Microsoft\\.OpenApi/", "/^YamlDotNet/"],
      "groupName": "openapi",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "OpenTelemetry",
      "matchPackageNames": ["/^OpenTelemetry/"],
      "groupName": "opentelemetry",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Major bumps require manual review",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major"]
    },
    {
      "description": ".NET SDK — stable channel only, block previews",
      "matchManagers": ["dotnet-sdk"],
      "matchPackageNames": ["dotnet-sdk"],
      "allowedVersions": "/^[0-9]+\\.[0-9]+\\.[0-9]+$/"
    }
  ],
  "customManagers": [
    {
      "description": "Version.props — Roslyn",
      "customType": "regex",
      "managerFilePatterns": ["(^|/)Version\\.props$"],
      "matchStrings": ["<RoslynVersion>(?<currentValue>[^<]+)</RoslynVersion>"],
      "depNameTemplate": "Microsoft.CodeAnalysis.CSharp",
      "datasourceTemplate": "nuget"
